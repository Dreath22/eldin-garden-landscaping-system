# Environment Configuration Template
# Copy this to .env and update values for your environment

# Database Configuration (XAMPP defaults)
DB_HOST=localhost
DB_NAME=landscaping
DB_USER=root
DB_PASS=

# Application Settings
APP_ENV=development
DEBUG=true
TIMEZONE=Asia/Manila

# File Paths
UPLOADS_PATH=uploads/
CACHE_PATH=cache/

# Security Settings
SESSION_LIFETIME=3600
MAX_FILE_SIZE=5242880

# Email Settings (if using)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
